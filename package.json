{
  "name": "radium-launcher",
  "version": "1.0.0",
  "description": "Radium — Custom Rec Room Private Server Launcher",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.radium.launcher",
    "productName": "Radium Launcher",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "logo.png",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "electron-store": "^10.0.1"
  }
}
